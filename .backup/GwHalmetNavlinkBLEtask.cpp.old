/**
 * NavLink BLE Channel for Halmet
 * 
 * Lightweight N2K message streaming over BLE.
 * Uses NavLink Blue (PDGY) format for bidirectional message exchange.
 * 
 * Architecture:
 * - Uses beginCallbackOnly() for lightweight channel
 * - Output: callback queues msg -> txProcessor formats to PDGY -> BLE notify
 * - Input: BLE write -> queue -> microtask parse PDGY -> handleN2kMessage()
 * 
 * Both directions use queues because callbacks can run from any context
 * (timer daemon, main loop, etc.) but NimBLE needs consistent context.
 * 
 * BLE Service: ABF0 (NavLink Blue)
 * Characteristic: ABF2 (read/write/notify)
 */
#include "GwHalmetNavlinkBLETask.h"

#ifdef BOARD_HALMET
#ifdef NAVLINK_BLE_ENABLED

#include "GwApi.h"
#include "GwLog.h"
#include "GwChannel.h"
#include "GwChannelList.h"
#include "GwPdgyUtils.h"
#include "GwHalmetTask.h"
#include "N2kMsg.h"
#include <NimBLEDevice.h>

extern GwChannelList channels;
extern void handleN2kMessage(const tN2kMsg &n2kMsg, int sourceId, bool isConverted);

#define BLE_CHANNEL_ID 252

#define SERVICE_UUID        "ABF0"
#define CHARACTERISTIC_UUID "ABF2"
#define BLE_DEVICE_NAME     "NAVLinkBlue-1234"

// Queues for deferred processing
// RX: BLE write callback runs in nimble_host task
// TX: Callback can run from timer daemon - not safe for NimBLE
#define BLE_RX_QUEUE_SIZE 4
#define BLE_RX_MSG_SIZE 128
#define BLE_TX_QUEUE_SIZE 16

// Compact TX message structure
struct BleTxMsg {
    unsigned long pgn;
    uint8_t priority;
    uint8_t source;
    uint8_t dest;
    uint8_t dataLen;
    uint8_t data[8];
};

static QueueHandle_t g_bleRxQueue = nullptr;
static QueueHandle_t g_bleTxQueue = nullptr;

static GwLog* g_logger = nullptr;
static GwChannel* g_bleChannel = nullptr;
static NimBLEServer* g_bleServer = nullptr;
static NimBLECharacteristic* g_bleCharacteristic = nullptr;
static unsigned long g_messageCount = 0;
static unsigned long g_droppedCount = 0;

/**
 * N2K message callback - queues for thread-safe TX.
 * Called from any context (main loop, timer daemon, etc.)
 */
static void handleOutgoingN2k(const tN2kMsg& msg, int sourceId) {
    if (!g_bleTxQueue) return;
    if (!g_bleServer || g_bleServer->getConnectedCount() == 0) return;
    
    BleTxMsg txMsg;
    txMsg.pgn = msg.PGN;
    txMsg.priority = msg.Priority;
    txMsg.source = msg.Source;
    txMsg.dest = msg.Destination;
    txMsg.dataLen = (msg.DataLen > 8) ? 8 : msg.DataLen;
    memcpy(txMsg.data, msg.Data, txMsg.dataLen);
    
    if (xQueueSend(g_bleTxQueue, &txMsg, 0) != pdTRUE) {
        g_droppedCount++;
    }
}

/**
 * Process incoming PDGY message (called from micro-task with proper stack).
 */
static bool processIncoming(const char* pdgyLine) {
    if (strncmp(pdgyLine, "!PDGY,", 6) != 0) {
        return false;
    }
    
    tN2kMsg msg;
    if (!pdgyToN2kMsg(pdgyLine, msg)) {
        return false;
    }
    
    handleN2kMessage(msg, BLE_CHANNEL_ID, false);
    return true;
}

// BLE characteristic write callback
class CharacteristicCallbacks: public NimBLECharacteristicCallbacks {
    void onWrite(NimBLECharacteristic* pCharacteristic, NimBLEConnInfo& connInfo) override {
        std::string value = pCharacteristic->getValue();
        
        if (value.length() > 0 && value.length() < BLE_RX_MSG_SIZE && g_bleRxQueue) {
            char msgBuf[BLE_RX_MSG_SIZE];
            size_t len = value.length();
            memcpy(msgBuf, value.c_str(), len);
            
            while (len > 0 && (msgBuf[len-1] == '\r' || msgBuf[len-1] == '\n')) {
                len--;
            }
            msgBuf[len] = '\0';
            
            if (xQueueSend(g_bleRxQueue, msgBuf, 0) != pdTRUE) {
                if (g_logger) {
                    g_logger->logDebug(GwLog::DEBUG, "BLE: rx queue full");
                }
            }
        }
    }
};

// BLE server callbacks
class ServerCallbacks: public NimBLEServerCallbacks {
public:
    void onConnect(NimBLEServer* pServer, NimBLEConnInfo& connInfo) override {
        if (g_logger) {
            g_logger->logDebug(GwLog::LOG, "BLE: connected, count=%d", pServer->getConnectedCount());
        }
        
        if (pServer->getConnectedCount() == 1 && g_bleChannel) {
            g_bleChannel->enable(true);
        }
    }
    
    void onDisconnect(NimBLEServer* pServer, NimBLEConnInfo& connInfo, int reason) override {
        if (g_logger) {
            g_logger->logDebug(GwLog::LOG, "BLE: disconnected, count=%d", pServer->getConnectedCount());
        }
        
        if (pServer->getConnectedCount() == 0 && g_bleChannel) {
            g_bleChannel->enable(false);
        }
    }
};

static bool initializeBLE() {
    NimBLEDevice::init("");
    NimBLEDevice::setPower(ESP_PWR_LVL_P9);
    NimBLEDevice::setSecurityAuth(false, false, false);

    g_bleServer = NimBLEDevice::createServer();
    if (!g_bleServer) {
        if (g_logger) g_logger->logDebug(GwLog::ERROR, "BLE: createServer() failed");
        return false;
    }
    g_bleServer->advertiseOnDisconnect(true);
    g_bleServer->setCallbacks(new ServerCallbacks());
    
    NimBLEService* pService = g_bleServer->createService(SERVICE_UUID);
    if (!pService) {
        if (g_logger) g_logger->logDebug(GwLog::ERROR, "BLE: createService() failed");
        return false;
    }
    
    g_bleCharacteristic = pService->createCharacteristic(
        CHARACTERISTIC_UUID,
        NIMBLE_PROPERTY::READ | NIMBLE_PROPERTY::WRITE | NIMBLE_PROPERTY::NOTIFY
    );
    g_bleCharacteristic->setCallbacks(new CharacteristicCallbacks());
    
    return true;
}

static void startAdvertising() {
    NimBLEAdvertising* pAdvertising = NimBLEDevice::getAdvertising();
    if (!pAdvertising) return;
    
    pAdvertising->addServiceUUID(SERVICE_UUID);
    
    NimBLEAdvertisementData advertisementData;
    advertisementData.setName(BLE_DEVICE_NAME);
    advertisementData.setCompleteServices(NimBLEUUID(SERVICE_UUID));
    pAdvertising->setAdvertisementData(advertisementData);
    
    NimBLEAdvertisementData scanResponseData;
    scanResponseData.setName(BLE_DEVICE_NAME);
    pAdvertising->setScanResponseData(scanResponseData);
    pAdvertising->start();
}

// Process RX queue - called from rxProcessor in main channel loop
static void processRxQueue() {
    if (!g_bleRxQueue) return;
    
    char msgBuf[BLE_RX_MSG_SIZE];
    int processed = 0;
    while (processed < 10 && xQueueReceive(g_bleRxQueue, msgBuf, 0) == pdTRUE) {
        processIncoming(msgBuf);
        processed++;
    }
}

// Process TX queue - called from txProcessor in main channel loop
static void processTxQueue() {
    if (!g_bleTxQueue || !g_bleCharacteristic || !g_bleServer ||
        g_bleServer->getConnectedCount() == 0) return;
    
    BleTxMsg txMsg;
    int sent = 0;
    while (sent < 10 && xQueueReceive(g_bleTxQueue, &txMsg, 0) == pdTRUE) {
        // Reconstruct and format
        tN2kMsg msg;
        msg.Init(txMsg.priority, txMsg.pgn, txMsg.source, txMsg.dest);
        for (int i = 0; i < txMsg.dataLen; i++) msg.AddByte(txMsg.data[i]);
        
        char pdgyMsg[320];
        int len = n2kMsgToPdgy(msg, pdgyMsg, sizeof(pdgyMsg) - 3);
        if (len > 0) {
            pdgyMsg[len++] = '\r';
            pdgyMsg[len++] = '\n';
            pdgyMsg[len] = '\0';
            g_bleCharacteristic->setValue((uint8_t*)pdgyMsg, len);
            g_bleCharacteristic->notify();
            g_messageCount++;
            sent++;
        }
    }
}

// Micro-task: advertising restart and fallback queue processing
static void bleMicroTask(GwApi* api) {
    // Fallback RX/TX processing in case main loop is slow
    processRxQueue();
    processTxQueue();
    
    // Restart advertising if needed
    if (g_bleServer && g_bleServer->getConnectedCount() == 0) {
        if (!NimBLEDevice::getAdvertising()->isAdvertising()) {
            if (g_logger) g_logger->logDebug(GwLog::LOG, "BLE: restarting advertising");
            NimBLEDevice::getAdvertising()->start();
        }
    }
}

void navlinkBLEInit(GwApi* api) {
    g_logger = api->getLogger();
    
    bool enabled = api->getConfig()->getConfigItem(api->getConfig()->navlinkEnable, true)->asBoolean();
    if (!enabled) {
        g_logger->logDebug(GwLog::LOG, "BLE: disabled by config");
        esp_bt_controller_disable();
        esp_bt_controller_deinit();
        esp_bt_controller_mem_release(ESP_BT_MODE_BLE);
        return;
    }
    
    g_logger->logDebug(GwLog::LOG, "BLE: init");
    
    // Create RX queue for incoming messages
    g_bleRxQueue = xQueueCreate(BLE_RX_QUEUE_SIZE, BLE_RX_MSG_SIZE);
    if (!g_bleRxQueue) {
        g_logger->logDebug(GwLog::ERROR, "BLE: failed to create rx queue");
        return;
    }
    
    // Create TX queue for thread-safe outgoing messages
    g_bleTxQueue = xQueueCreate(BLE_TX_QUEUE_SIZE, sizeof(BleTxMsg));
    if (!g_bleTxQueue) {
        g_logger->logDebug(GwLog::ERROR, "BLE: failed to create tx queue");
        vQueueDelete(g_bleRxQueue);
        g_bleRxQueue = nullptr;
        return;
    }
    
    if (!initializeBLE()) {
        g_logger->logDebug(GwLog::ERROR, "BLE: init failed");
        vQueueDelete(g_bleRxQueue);
        vQueueDelete(g_bleTxQueue);
        g_bleRxQueue = nullptr;
        g_bleTxQueue = nullptr;
        return;
    }
    
    startAdvertising();
    g_logger->logDebug(GwLog::LOG, "BLE: initialized and advertising");
    
    // Create lightweight callback-only channel
    g_bleChannel = new GwChannel(g_logger, "BLE", BLE_CHANNEL_ID, -1);
    g_bleChannel->beginCallbackOnly(handleOutgoingN2k);
    
    // RX/TX processing runs in main channel loop for low latency
    g_bleChannel->setRxProcessor(processRxQueue);
    g_bleChannel->setTxProcessor(processTxQueue);
    
    // Start disabled until clients connect
    g_bleChannel->enable(false);
    
    channels.addChannel(g_bleChannel);
    g_logger->logDebug(GwLog::LOG, "BLE: callback channel added (ID=%d)", BLE_CHANNEL_ID);
    
    halmetRegisterMicroTask("BLE", bleMicroTask);
}

#endif  // NAVLINK_BLE_ENABLED
#endif  // BOARD_HALMET
